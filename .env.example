# ──────────────────────────────────────────────────────────────────────────
# OlivoWeb — variables de entorno
# Copia este archivo a .env.local y completa los valores. NUNCA commitees
# valores reales: .env* está en .gitignore.
# ──────────────────────────────────────────────────────────────────────────

# ── App ──
NEXT_PUBLIC_SITE_URL=https://olivomarket.cl

# ── NextAuth ──
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://olivomarket.cl

# Google OAuth (opcional; si faltan, el proveedor se deshabilita)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Emails (separados por coma) que se elevan a ADMIN al entrar con Google.
# OBLIGATORIO si usas Google OAuth para administrar: no hay fallback.
GOOGLE_ADMIN_EMAILS=

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: SOLO en servidor. Rotar periódicamente.
SUPABASE_SERVICE_ROLE_KEY=

# ── MercadoPago ──
MERCADOPAGO_ACCESS_TOKEN=
# Secret de firma de webhooks (panel MP → Tus integraciones → Webhooks).
# Sin él, la firma de las notificaciones de pago NO se verifica.
MERCADOPAGO_WEBHOOK_SECRET=

# ── Emails (Resend) ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=

# ── Cloudinary (imágenes) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Operación ──
# Protege /api/cron/auto-close-shifts (Vercel lo envía como Bearer).
# OBLIGATORIO: sin él, el cron responde 401 siempre.
CRON_SECRET=
# Token de un solo uso para crear el primer admin (/api/admin/bootstrap).
# Generar con: openssl rand -hex 32. Se deshabilita solo tras el primer admin.
ADMIN_SETUP_TOKEN=
